# This file is managed by Ansible.
# UBUNTU26-STIG: login.defs.j2

MAIL_DIR        /var/mail
FAILLOG_ENAB		yes
LOG_UNKFAIL_ENAB	no
LOG_OK_LOGINS		no

SYSLOG_SU_ENAB		yes
SYSLOG_SG_ENAB		yes

FTMP_FILE	/var/log/btmp

SU_NAME		su

# Password aging controls
PASS_MAX_DAYS   {{ ubtu26stig_pwd_max_age }}
PASS_MIN_DAYS   {{ ubtu26stig_pwd_min_age }}
PASS_WARN_AGE   {{ ubtu26stig_pwd_warn_age }}

UID_MIN                  1000
UID_MAX                 60000
SYS_UID_MIN               100
SYS_UID_MAX               999
GID_MIN                  1000
GID_MAX                 60000
SYS_GID_MIN               100
SYS_GID_MAX               999

LOGIN_RETRIES		5
LOGIN_TIMEOUT		60

CHFN_RESTRICT		rwh

DEFAULT_HOME	yes

USERGROUPS_ENAB yes

ENCRYPT_METHOD {{ ubtu26stig_pwd_encrypt_method }}
