plugin: amazon.aws.aws_ec2
regions:
  - ap-southeast-1
filters:
  instance-state-name: running
keyed_groups:
  - prefix: tag_Name
    key: tags.Name
hostnames:
  - instance-id

compose:
  ansible_connection: "'ssh'"
  # เพิ่ม -o StrictHostKeyChecking=no เข้าไปครับ
  ansible_ssh_common_args: "'-o StrictHostKeyChecking=no -o ProxyCommand=\"aws ssm start-session --target %h --document AWS-StartSSHSession --parameters portNumber=%p\"'


