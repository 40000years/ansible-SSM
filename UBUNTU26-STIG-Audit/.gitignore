/tmp/goss_vars_*.yml

# Editor artifacts
*.swp
*.swo
*~
.vscode/
.idea/

# Test environment
.vagrant/
*.retry

# Python virtual environments (if using for tooling)
.venv/
venv/

# Molecule test outputs
.molecule/

# Ansible inventory secrets
inventory/secrets*
