# UBUNTU26-STIG-Audit .gitignore

# OS-generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# goss output files
*.json
*.xml
*.txt
audit_output_*
goss_output_*

